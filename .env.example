# Copy to .env and fill in real values. .env is gitignored.
# Generate random secrets with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"

DB_USER=
DB_PASSWORD=
DB_NAME=
PRYZM_API_TOKEN=
SEARXNG_SECRET=

# Optional. JSON list of public-internet origins allowed by CORS, on top of
# the localhost defaults baked into config.py. Leave unset for LAN-only use.
# Example:
#   CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","https://your-hostname.example"]
# CORS_ORIGINS=
