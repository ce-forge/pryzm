.env

ollama_models/
pgdata/
router_config.txt
backend/venv/

# Python bytecode anywhere in the tree. The original `backend/__pycache__/`
# only matched the top-level directory, so nested caches (db/, routers/,
# services/, alembic/, ...) ended up tracked.
**/__pycache__/
*.pyc
.pytest_cache/
**/.pytest_cache/
backend/tests/e2e/_artifacts/

frontend/node_modules/
frontend/.next/

*.db
*.sqlite3

# Local Postgres dumps (pg_dump output from pryzm_core / pryzm_test). These
# are safety-net backups taken before destructive ops; never commit raw data.
pryzm_*.sql

.DS_Store
Thumbs.db

# Dev dashboard runtime artefacts (UMAP pickle, future runtime files).
# Kept here on main so the pickle stays ignored regardless of which
# branch is checked out — see backend/data/.gitkeep on feature/dev-dashboard.
backend/data/*
!backend/data/.gitkeep

# Codemap dev tool output.
backend/tests/codemap/_out/

# Internal / brainstorm / sensitive docs that stay on the dev box, not on
# GitHub. Everything in docs/specs/ and docs/plans/ is fair game to commit;
# anything in docs/internal/ is local-only.
docs/internal/
